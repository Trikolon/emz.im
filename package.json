{
  "name": "emz.im",
  "description": "Emma's personal website.",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "site": {
    "url": "https://emz.im",
    "authorName": "Emma Zühlcke"
  },
  "scripts": {
    "prettier": "prettier --config .prettierrc '{src,scripts}/**/*.{ts,js,cjs}' --write",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "lint": "pnpm run prettier && pnpm run eslint && tsc --noEmit",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "convert-photos": "scripts/photos/convertPhotos.cjs"
  },
  "author": "Emma Zuehlcke",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lit/reactive-element": "^2.1.2",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-wc": "^3.1.0",
    "exifr": "^7.1.3",
    "node-html-parser": "^7.1.0",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9"
  },
  "dependencies": {
    "lit": "^3.3.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
